<section class="container" style="margin-top: 12rem;">
    <div class="section-header">
        <div>
            <p style="color: #22c55e; font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">GET IN TOUCH</p>
            <h2 style="font-size: 4rem; font-weight: 900; letter-spacing: -2px;">Contact Us</h2>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 5rem; align-items: start;">
        <!-- Contact Form -->
        <div class="card" style="padding: 4rem; border-radius: 60px; background: white;">
            <form action="#" method="POST">
                <div style="margin-bottom: 2rem;">
                    <input type="text" name="Name" placeholder="Your Name" required style="width: 100%; padding: 1.2rem 2rem; background: var(--bg-beige); border: 2px solid transparent; border-radius: 30px; font-weight: 600; outline: none; transition: var(--transition);">
                </div>
                <div style="margin-bottom: 2rem;">
                    <input type="email" name="Email" placeholder="Email Address" required style="width: 100%; padding: 1.2rem 2rem; background: var(--bg-beige); border: 2px solid transparent; border-radius: 30px; font-weight: 600; outline: none; transition: var(--transition);">
                </div>
                <div style="margin-bottom: 2rem;">
                    <textarea name="Message" placeholder="How can we help?" required style="width: 100%; padding: 1.2rem 2rem; background: var(--bg-beige); border: 2px solid transparent; border-radius: 30px; font-weight: 600; outline: none; transition: var(--transition); height: 150px; resize: none;"></textarea>
                </div>
                <button type="submit" class="cart-btn" style="width: 100%; padding: 1.5rem; font-size: 1.1rem; justify-content: center;">Send Message</button>
            </form>
        </div>

        <!-- Contact Info -->
        <div style="padding: 2rem;">
            <div style="margin-bottom: 4rem;">
                <h3 style="font-size: 2rem; font-weight: 900; margin-bottom: 1.5rem;">Reach Out</h3>
                <p style="color: var(--text-secondary); line-height: 1.8;">Our team is here to help you find the perfect pair. Whether you have a question about sizing or shipping, we've got you covered.</p>
            </div>

            <div style="display: grid; gap: 2.5rem;">
                <div style="display: flex; gap: 1.5rem; align-items: center;">
                    <div style="background: var(--accent); width: 60px; height: 60px; border-radius: 20px; display: flex; align-items: center; justify-content: center;">
                        <i class="fa fa-phone" style="font-size: 1.5rem; color: var(--accent-dark);"></i>
                    </div>
                    <div>
                        <h4 style="font-weight: 800;">Phone</h4>
                        <p style="color: var(--text-secondary);">+1 234 567 890</p>
                    </div>
                </div>

                <div style="display: flex; gap: 1.5rem; align-items: center;">
                    <div style="background: var(--accent); width: 60px; height: 60px; border-radius: 20px; display: flex; align-items: center; justify-content: center;">
                        <i class="fa fa-envelope" style="font-size: 1.5rem; color: var(--accent-dark);"></i>
                    </div>
                    <div>
                        <h4 style="font-weight: 800;">Email</h4>
                        <p style="color: var(--text-secondary);">support@downy.com</p>
                    </div>
                </div>

                <div style="display: flex; gap: 1.5rem; align-items: center;">
                    <div style="background: var(--accent); width: 60px; height: 60px; border-radius: 20px; display: flex; align-items: center; justify-content: center;">
                        <i class="fa fa-map-marker" style="font-size: 1.5rem; color: var(--accent-dark);"></i>
                    </div>
                    <div>
                        <h4 style="font-weight: 800;">Location</h4>
                        <p style="color: var(--text-secondary);">Karachi, Pakistan</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    input:focus, textarea:focus {
        border-color: var(--accent) !important;
        background: white !important;
    }
</style>