<section class="container" style="margin-top: 12rem;">
    <div class="section-header">
        <div>
            <p style="color: #22c55e; font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">YOUR SELECTION</p>
            <h2 style="font-size: 4rem; font-weight: 900; letter-spacing: -2px;">Shopping Cart</h2>
        </div>
        {{#if cartCount}}
        <p style="background: var(--accent); color: var(--accent-dark); padding: 0.5rem 1.5rem; border-radius: 20px; font-weight: 800;">{{cartCount}} ITEMS</p>
        {{/if}}
    </div>

    {{#if Empty}}
    <div style="text-align: center; padding: 8rem 2rem; background: white; border-radius: 60px; margin-top: 4rem;">
        <div style="background: var(--bg-beige); width: 120px; height: 120px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 2rem;">
            <i class="fa fa-shopping-basket" style="font-size: 3rem; opacity: 0.2;"></i>
        </div>
        <h3 style="font-size: 2rem; font-weight: 800; margin-bottom: 1rem;">{{Empty}}</h3>
        <p style="color: var(--text-secondary); margin-bottom: 3rem;">Looks like you haven't added anything to your cart yet.</p>
        <a href="/shop" class="cart-btn" style="padding: 1.2rem 3rem;">Start Shopping</a>
    </div>
    {{else}}
    <div class="checkout-main-grid" style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 4rem; margin-top: 4rem; align-items: start;">
        <!-- Cart Items List -->
        <div style="display: grid; gap: 1.5rem;">
            {{#each Cartt}}
            <div class="card" style="display: flex; gap: 2rem; align-items: center; padding: 2rem; border-radius: 40px; text-align: left;">
                <div style="background: var(--bg-beige); padding: 1rem; border-radius: 30px; width: 150px; height: 150px; display: flex; align-items: center; justify-content: center;">
                    <img src="/{{this.Firstimg}}" style="width: 100%; transform: rotate(-10deg);">
                </div>
                <div style="flex: 1;">
                    <p style="color: #22c55e; font-weight: 700; font-size: 0.8rem; text-transform: uppercase;">{{this.size}} SIZE</p>
                    <h3 style="font-size: 1.5rem; font-weight: 800; margin: 0.5rem 0;">{{this.Pname}}</h3>
                    <p style="font-weight: 800; font-size: 1.2rem; color: var(--accent-dark); opacity: 0.6;">${{this.price}} x {{this.quantity}}</p>
                </div>
                <div style="text-align: right;">
                    <p style="font-size: 1.5rem; font-weight: 900; margin-bottom: 1rem;">${{this.PQ}}</p>
                    <form action="/checkout1" method="POST">
                        <input type="hidden" name="button" value="{{this.Pid}}">
                        <button type="submit" style="background: #fee2e2; color: #ef4444; border: none; width: 50px; height: 50px; border-radius: 20px; cursor: pointer; transition: var(--transition);">
                            <i class="fa fa-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
            {{/each}}
        </div>

        <!-- Order Summary & Checkout Form -->
        <div class="card summary-card" style="padding: 3rem; border-radius: 60px; background: white; position: sticky; top: 8rem;">
            <h3 style="font-size: 2rem; font-weight: 900; margin-bottom: 2rem;">Summary</h3>
            
            <div style="display: grid; gap: 1.5rem; margin-bottom: 2rem;">
                <div style="display: flex; justify-content: space-between;">
                    <span style="opacity: 0.5; font-weight: 600;">Subtotal</span>
                    <span style="font-weight: 800;">${{Total_price}}</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="opacity: 0.5; font-weight: 600;">Shipping</span>
                    <span style="color: #22c55e; font-weight: 800;">FREE</span>
                </div>
                <div style="display: flex; justify-content: space-between; border-top: 1px solid var(--bg-beige); pt: 1.5rem; margin-top: 0.5rem; font-size: 1.5rem;">
                    <span style="font-weight: 900;">Total</span>
                    <span style="font-weight: 900; color: #22c55e;">${{Total_price}}</span>
                </div>
            </div>

            <form action="/checkout" method="POST" style="display: grid; gap: 1rem;">
                <input type="text" name="name" placeholder="Full Name" required style="width: 100%; padding: 1rem 1.5rem; background: var(--bg-beige); border: 2px solid transparent; border-radius: 20px; font-weight: 600; outline: none; transition: var(--transition);">
                <input type="text" name="Mobile_no" placeholder="Mobile (e.g. 03001234567)" required style="width: 100%; padding: 1rem 1.5rem; background: var(--bg-beige); border: 2px solid transparent; border-radius: 20px; font-weight: 600; outline: none; transition: var(--transition);">
                <input type="email" name="email" placeholder="Email Address (for order tracking)" required style="width: 100%; padding: 1rem 1.5rem; background: var(--bg-beige); border: 2px solid transparent; border-radius: 20px; font-weight: 600; outline: none; transition: var(--transition);">
                <div class="city-zip-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <input type="text" name="City" placeholder="City" required style="width: 100%; padding: 1rem 1.5rem; background: var(--bg-beige); border: 2px solid transparent; border-radius: 20px; font-weight: 600; outline: none; transition: var(--transition);">
                    <input type="text" name="Postal_Code" placeholder="ZIP" required style="width: 100%; padding: 1rem 1.5rem; background: var(--bg-beige); border: 2px solid transparent; border-radius: 20px; font-weight: 600; outline: none; transition: var(--transition);">
                </div>
                <textarea name="Address" placeholder="Shipping Address" required style="width: 100%; padding: 1rem 1.5rem; background: var(--bg-beige); border: 2px solid transparent; border-radius: 20px; font-weight: 600; outline: none; transition: var(--transition); height: 100px; resize: none;"></textarea>
                
                <button type="submit" class="cart-btn" style="width: 100%; padding: 1.5rem; font-size: 1.2rem; justify-content: center; margin-top: 1rem;">
                    Continue to Payment
                </button>
            </form>
        </div>
    </div>
    {{/if}}
</section>

<style>
    input:focus, textarea:focus {
        border-color: var(--accent) !important;
        background: white !important;
    }

    @media (max-width: 991px) {
        .checkout-main-grid {
            grid-template-columns: 1fr !important;
            gap: 2rem !important;
        }
        .summary-card {
            position: static !important;
        }
    }

    @media (max-width: 480px) {
        .city-zip-grid {
            grid-template-columns: 1fr !important;
        }
    }
</style>