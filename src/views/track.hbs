<section class="container" style="margin-top: 15rem;">
    <div class="section-header" style="text-align: center; flex-direction: column;">
        <p style="color: #22c55e; font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">ORDER TRACKING</p>
        <h2 style="font-size: 4rem; font-weight: 900; letter-spacing: -3px;">Where is my Pair?</h2>
    </div>

    <div style="max-width: 600px; margin: 4rem auto;">
        <div class="card" style="padding: 4rem; border-radius: 60px; background: white;">
            <form action="/track" method="POST">
                <div style="margin-bottom: 2rem; text-align: left;">
                    <label style="font-weight: 800; font-size: 0.8rem; margin-left: 1.5rem; margin-bottom: 0.5rem; display: block; opacity: 0.4;">ORDER ID</label>
                    <input type="text" name="orderId" placeholder="Enter your Order # (e.g. 100001)" value="{{#if prefillId}}{{prefillId}}{{/if}}" required style="width: 100%; padding: 1.2rem 2rem; background: var(--bg-beige); border: 2px solid transparent; border-radius: 30px; font-weight: 700; outline: none; transition: var(--transition);">
                </div>
                <button type="submit" class="cart-btn" style="width: 100%; padding: 1.5rem; font-size: 1.2rem; justify-content: center;">Track Status</button>
            </form>
            
            {{#if error}}
            <p style="color: #ef4444; font-weight: 700; margin-top: 2rem; text-align: center;">{{error}}</p>
            {{/if}}

        </div>
    </div>

    {{#if order}}
    <div id="results" style="max-width: 800px; margin: 5rem auto;">
        <div class="card" style="padding: 5rem; border-radius: 60px; background: var(--accent-dark); color: white; text-align: left;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 2rem;">
                <div>
                    <p style="opacity: 0.5; font-weight: 700;">STATUS</p>
                    <h3 style="font-size: 2.5rem; font-weight: 900; color: var(--accent);">{{order.status}}</h3>
                </div>
                <div style="text-align: right;">
                    <p style="opacity: 0.5; font-weight: 700;">CUSTOMER</p>
                    <h4 style="font-size: 1.5rem; font-weight: 800;">{{order.Full_name}}</h4>
                </div>
            </div>

            <h4 style="font-weight: 900; margin-bottom: 2rem; opacity: 0.3; text-transform: uppercase;">Items in this order</h4>
            <div style="display: grid; gap: 1.5rem;">
                {{#each details}}
                <div style="display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.05); padding: 1.5rem; border-radius: 30px;">
                    <div style="display: flex; gap: 2rem; align-items: center;">
                        <img src="{{getImageUrl this.Firstimg}}" style="width: 60px; transform: rotate(-15deg);">
                        <div>
                            <p style="font-weight: 800;">{{this.Pname}}</p>
                            <p style="font-size: 0.8rem; opacity: 0.5;">Size: {{this.size}} | Qty: {{this.quantity}}</p>
                        </div>
                    </div>
                    <p style="font-weight: 900; font-size: 1.2rem;">${{this.PQ}}</p>
                </div>
                {{/each}}
            </div>
            
            <p style="margin-top: 4rem; text-align: center; opacity: 0.4; font-size: 0.9rem;">
                Shipping Address: {{order.Address}}, {{order.City}}
            </p>
        </div>
    </div>
    {{/if}}
</section>
