<section class="container" style="margin-top: 12rem;">
    <div class="section-header">
        <div>
            <p style="color: #22c55e; font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">INVENTORY MANAGEMENT</p>
            <h2 style="font-size: 4rem; font-weight: 900; letter-spacing: -2px;">Live Stock</h2>
        </div>
        <div style="display: flex; gap: 1rem;">
            <a href="/checkrecord" class="cart-btn" style="background: white; color: var(--accent-dark); border: 2px solid var(--accent-dark); padding: 0.8rem 1.5rem; font-size: 0.8rem;">View Orders</a>
            <a href="/stockupdate" class="cart-btn" style="padding: 0.8rem 1.5rem; font-size: 0.8rem;">Quick Update</a>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 2rem; margin-top: 4rem;">
        {{#each objectArray}}
        <div class="card" style="padding: 3rem; border-radius: 50px; background: white; text-align: left;">
            <div style="display: flex; gap: 2rem; align-items: center; margin-bottom: 2rem;">
                <div style="background: var(--bg-beige); padding: 1rem; border-radius: 30px; width: 100px; height: 100px; display: flex; align-items: center; justify-content: center;">
                    <img src="{{getImageUrl this.Firstimg}}" style="width: 100%; transform: rotate(-10deg);">
                </div>
                <div>
                    <p style="opacity: 0.4; font-weight: 800; font-size: 0.8rem;">PRODUCT ID</p>
                    <h3 style="font-size: 1.5rem; font-weight: 900;">#{{this.Pname}}</h3>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="stock-item">
                    <span>SIZE 40</span>
                    <strong>{{this.size40}}</strong>
                </div>
                <div class="stock-item">
                    <span>SIZE 41</span>
                    <strong>{{this.size41}}</strong>
                </div>
                <div class="stock-item">
                    <span>SIZE 42</span>
                    <strong>{{this.size42}}</strong>
                </div>
                <div class="stock-item">
                    <span>SIZE 43</span>
                    <strong>{{this.size43}}</strong>
                </div>
            </div>

            <a href="/stockupdate?id={{this.Pname}}" class="cart-btn" style="width: 100%; margin-top: 2rem; justify-content: center; background: var(--bg-beige); color: var(--accent-dark); border: none;">
                Refill Stock
            </a>
        </div>
        {{/each}}
    </div>
</section>

<style>
    .stock-item {
        background: var(--bg-beige);
        padding: 1.5rem;
        border-radius: 25px;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .stock-item span {
        font-size: 0.7rem;
        font-weight: 800;
        opacity: 0.4;
    }
    .stock-item strong {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--accent-dark);
    }
</style>