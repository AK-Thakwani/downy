<section class="container" style="margin-top: 12rem;">
    <div class="section-header">
        <div>
            <p style="color: #22c55e; font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">INVENTORY REFILL</p>
            <h2 style="font-size: 4rem; font-weight: 900; letter-spacing: -2px;">Update Stock</h2>
        </div>
        <a href="/checkstock" class="cart-btn" style="background: white; color: var(--accent-dark); border: 2px solid var(--accent-dark); padding: 0.8rem 1.5rem; font-size: 0.8rem;">Check All Stock</a>
    </div>

    {{#if MSGGG}}
    <div style="background: var(--accent); color: var(--accent-dark); padding: 1rem 2rem; border-radius: 20px; margin-top: 2rem; font-weight: 700; text-align: center; box-shadow: 0 10px 20px rgba(188, 255, 47, 0.2);">
        <i class="fa fa-sync-alt"></i> {{MSGGG}}
    </div>
    {{/if}}

    <div style="display: flex; justify-content: center; margin-top: 4rem;">
        <div class="card" style="width: 100%; max-width: 600px; padding: 5rem; border-radius: 60px; background: white;">
            <form action="/stockupdate" method="POST">
                <div style="margin-bottom: 2.5rem; text-align: left;">
                    <label class="form-label">PRODUCT ID</label>
                    <input type="number" name="productid" value="{{query.id}}" placeholder="Enter ID (e.g. 32)" required class="form-input">
                </div>

                <div style="margin-bottom: 2.5rem; text-align: left;">
                    <label class="form-label">SELECT SIZE</label>
                    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;">
                        <label class="size-opt">
                            <input type="radio" name="productsize" value="40" checked class="size-radio-input">
                            <div class="size-box">40</div>
                        </label>
                        <label class="size-opt">
                            <input type="radio" name="productsize" value="41" class="size-radio-input">
                            <div class="size-box">41</div>
                        </label>
                        <label class="size-opt">
                            <input type="radio" name="productsize" value="42" class="size-radio-input">
                            <div class="size-box">42</div>
                        </label>
                        <label class="size-opt">
                            <input type="radio" name="productsize" value="43" class="size-radio-input">
                            <div class="size-box">43</div>
                        </label>
                    </div>
                </div>

                <div style="margin-bottom: 3.5rem; text-align: left;">
                    <label class="form-label">ADD QUANTITY</label>
                    <input type="number" name="quantity" placeholder="e.g. 50" required class="form-input">
                    <p style="font-size: 0.7rem; opacity: 0.4; margin-top: 0.5rem; margin-left: 1.5rem;">Value will be added to current stock.</p>
                </div>

                <button type="submit" class="cart-btn" style="width: 100%; padding: 1.5rem; font-size: 1.2rem; justify-content: center;">
                    Update Inventory <i class="fa fa-boxes" style="margin-left: 1rem;"></i>
                </button>
            </form>
        </div>
    </div>
</section>

<style>
    .form-label {
        font-weight: 800;
        font-size: 0.7rem;
        color: var(--text-primary);
        opacity: 0.5;
        margin-left: 1.5rem;
        margin-bottom: 0.8rem;
        display: block;
        letter-spacing: 1px;
    }
    .form-input {
        width: 100%;
        padding: 1.2rem 2rem;
        background: var(--bg-beige);
        border: 2px solid transparent;
        border-radius: 25px;
        font-weight: 700;
        outline: none;
        transition: var(--transition);
    }
    .form-input:focus {
        border-color: var(--accent);
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .size-opt { cursor: pointer; }
    .size-radio-input { display: none; }
    .size-box {
        background: var(--bg-beige);
        padding: 1rem;
        border-radius: 20px;
        text-align: center;
        font-weight: 800;
        transition: var(--transition);
        border: 2px solid transparent;
    }
    .size-radio-input:checked + .size-box {
        background: var(--accent-dark);
        color: var(--accent);
        transform: scale(1.1);
    }
</style>