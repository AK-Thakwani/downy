<section class="container" style="margin-top: 12rem;">
    <div class="section-header">
        <div>
            <p style="color: #22c55e; font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">INVENTORY ADDITION</p>
            <h2 style="font-size: 4rem; font-weight: 900; letter-spacing: -2px;">New Product</h2>
        </div>
        <a href="/adminpage" class="cart-btn" style="background: white; color: var(--accent-dark); border: 2px solid var(--accent-dark); padding: 0.8rem 1.5rem; font-size: 0.8rem;">Back to Dashboard</a>
    </div>

    {{#if MSGGG}}
    <div style="background: #22c55e; color: white; padding: 1rem 2rem; border-radius: 20px; margin-top: 2rem; font-weight: 700; text-align: center; box-shadow: 0 10px 20px rgba(34, 197, 94, 0.2);">
        <i class="fa fa-check-circle"></i> {{MSGGG}}
    </div>
    {{/if}}

    <div class="card" style="margin-top: 4rem; padding: 5rem; border-radius: 60px; background: white;">
        <form action="/insertproduct" method="POST" enctype="multipart/form-data" style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem;">
            <!-- Left Side: Basic Info -->
            <div style="display: grid; gap: 2rem;">
                <h3 style="font-size: 1.5rem; font-weight: 900; margin-bottom: 1rem; opacity: 0.3;">BASIC DETAILS</h3>
                
                <div style="text-align: left;">
                    <label class="form-label">PRODUCT ID</label>
                    <input type="number" name="productid" placeholder="e.g. 101" required class="form-input">
                </div>
                
                <div style="text-align: left;">
                    <label class="form-label">PRODUCT NAME</label>
                    <input type="text" name="productname" placeholder="e.g. Urban Runner" required class="form-input">
                </div>

                <div style="text-align: left;">
                    <label class="form-label">CATEGORY</label>
                    <select name="Category" class="form-input" style="appearance: none;">
                        <option value="Sneakers">Sneakers</option>
                        <option value="Formals">Formals</option>
                        <option value="Casuals">Casuals</option>
                        <option value="Sandals">Sandals</option>
                    </select>
                </div>

                <div style="text-align: left;">
                    <label class="form-label">PRICE ($)</label>
                    <input type="number" name="price" placeholder="e.g. 120" required class="form-input">
                </div>
            </div>

            <!-- Right Side: Images & Stock -->
            <div style="display: grid; gap: 2rem;">
                <h3 style="font-size: 1.5rem; font-weight: 900; margin-bottom: 1rem; opacity: 0.3;">ASSETS & STOCK</h3>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
                    <div style="text-align: left;">
                        <label class="form-label">IMG 1 (Main)</label>
                        <input type="file" name="uploadimage1" accept="image/*" required class="form-input" style="font-size: 0.8rem; padding: 1rem;">
                    </div>
                    <div style="text-align: left;">
                        <label class="form-label">IMG 2</label>
                        <input type="file" name="uploadimage2" accept="image/*" required class="form-input" style="font-size: 0.8rem; padding: 1rem;">
                    </div>
                    <div style="text-align: left;">
                        <label class="form-label">IMG 3</label>
                        <input type="file" name="uploadimage3" accept="image/*" required class="form-input" style="font-size: 0.8rem; padding: 1rem;">
                    </div>
                </div>

                <div style="background: var(--bg-beige); padding: 2rem; border-radius: 30px;">
                    <label class="form-label" style="margin-bottom: 1.5rem; display: block;">INITIAL STOCK BY SIZE</label>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <input type="number" name="Quantity40" placeholder="Size 40 Qty" required class="form-input" style="background: white;">
                        <input type="number" name="Quantity41" placeholder="Size 41 Qty" required class="form-input" style="background: white;">
                        <input type="number" name="Quantity42" placeholder="Size 42 Qty" required class="form-input" style="background: white;">
                        <input type="number" name="Quantity43" placeholder="Size 43 Qty" required class="form-input" style="background: white;">
                    </div>
                </div>

                <button type="submit" class="cart-btn" style="width: 100%; padding: 1.5rem; font-size: 1.2rem; justify-content: center; margin-top: 1rem;">
                    Deploy Product <i class="fa fa-cloud-upload-alt" style="margin-left: 1rem;"></i>
                </button>
            </div>
        </form>
    </div>
</section>

<style>
    .form-label {
        font-weight: 800;
        font-size: 0.7rem;
        color: var(--text-primary);
        opacity: 0.5;
        margin-left: 1.5rem;
        margin-bottom: 0.5rem;
        display: block;
        letter-spacing: 1px;
    }
    .form-input {
        width: 100%;
        padding: 1.2rem 2rem;
        background: var(--bg-beige);
        border: 2px solid transparent;
        border-radius: 25px;
        font-weight: 700;
        outline: none;
        transition: var(--transition);
        font-family: inherit;
    }
    .form-input:focus {
        border-color: var(--accent);
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
</style>