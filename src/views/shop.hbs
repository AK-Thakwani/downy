<section class="container" style="margin-top: 12rem;">
    <div class="section-header" style="flex-direction: column; align-items: flex-start; gap: 2rem;">
        <div>
            <p style="color: #22c55e; font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">EXPLORE COLLECTION</p>
            <h2 style="font-size: 4rem; font-weight: 900; letter-spacing: -2px;">{{categoryName}}</h2>
        </div>
        
        <!-- Sorting UI -->
        <div style="display: flex; gap: 1rem; flex-wrap: wrap; background: white; padding: 1rem; border-radius: 30px; box-shadow: var(--shadow);">
            <p style="font-weight: 700; opacity: 0.5; margin: 0 1rem; align-self: center;">SORT BY:</p>
            <a href="?sort=default" class="sort-link {{#if (eq activeSort 'default')}}active{{/if}}">Default</a>
            <a href="?sort=price-low" class="sort-link {{#if (eq activeSort 'price-low')}}active{{/if}}">Price: Low to High</a>
            <a href="?sort=price-high" class="sort-link {{#if (eq activeSort 'price-high')}}active{{/if}}">Price: High to Low</a>
            <a href="?sort=az" class="sort-link {{#if (eq activeSort 'az')}}active{{/if}}">A-Z</a>
            <a href="?sort=za" class="sort-link {{#if (eq activeSort 'za')}}active{{/if}}">Z-A</a>
            <a href="?sort=selling" class="sort-link {{#if (eq activeSort 'selling')}}active{{/if}}">Most Selling</a>
        </div>
    </div>
    
    <div class="product-grid" style="margin-top: 4rem;">
        {{#each products}}
            {{> productCard category=../categoryName}}
        {{/each}}
    </div>
</section>

<style>
    .sort-link {
        text-decoration: none;
        color: var(--text-primary);
        font-weight: 700;
        font-size: 0.8rem;
        padding: 0.6rem 1.2rem;
        border-radius: 20px;
        transition: var(--transition);
        opacity: 0.5;
    }
    .sort-link:hover {
        opacity: 1;
        background: var(--bg-beige);
    }
    .sort-link.active {
        opacity: 1;
        background: var(--accent-dark);
        color: var(--accent);
    }
</style>